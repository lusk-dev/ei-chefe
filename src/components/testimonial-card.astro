---
import ImageIcon from '@lucide/astro/icons/image';
import { cn } from '@/lib/utils';
import type { Testimonial } from '@/data/testimonials';

interface Props {
  testimonial: Testimonial;
  className?: string;
}

const { testimonial, className } = Astro.props;
const { name, business, quote, extra, media, stagger } = testimonial;

const staggerClass =
  stagger === 'up'
    ? 'md:motion-safe:translate-y-16'
    : stagger === 'down'
      ? 'md:motion-safe:-translate-y-0'
      : '';
---

<article
  class={cn('group relative flex flex-col', staggerClass, className)}
  aria-label={`Depoimento de ${name}`}
>
  {
    media.type === 'text' ? (
      <div class="flex flex-col gap-4 rounded-2xl bg-white p-8 shadow-lg ring-1 ring-black/5 md:min-h-[320px] md:justify-center">
        <div>
          <h3 class="text-xl font-semibold text-[#151515]">{name}</h3>
          <p class="mt-1 text-sm font-medium text-[#3219CA]">{business}</p>
        </div>
        <blockquote class="text-base leading-relaxed text-[#151515]/90">
          &ldquo;{quote}&rdquo;
        </blockquote>
      </div>
    ) : (
      <div class="relative overflow-hidden rounded-2xl shadow-lg ring-1 ring-black/5">
        <div class="relative aspect-[9/16] w-full bg-muted">
          {media.type === 'video' ? (
            <iframe
              src={`https://www.youtube.com/embed/${media.youtubeId}?controls=1&rel=0&playsinline=0&modestbranding=0&autoplay=0`}
              title={`Depoimento de ${name}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              class="absolute inset-0 h-full w-full"
            />
          ) : media.src ? (
            <img
              src={media.src}
              alt={media.alt}
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover"
            />
          ) : (
            <div
              class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-[#EFEFEF] text-[#151515]/60"
              role="img"
              aria-label={media.alt}
            >
              <ImageIcon class="size-10 stroke-[1.5]" aria-hidden="true" />
              <span class="text-sm font-medium">Em breve</span>
            </div>
          )}

          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/95 via-black/75 to-transparent px-5 pb-5 pt-28"
            aria-hidden="true"
          />
        </div>

        <div class="absolute inset-x-0 bottom-0 px-5 pb-5">
          <h3 class="text-lg font-semibold text-white drop-shadow-sm">{name}</h3>
          <p
            class="mt-1.5 inline-block rounded-md bg-[#604EE9] px-2.5 py-1 text-xs font-semibold leading-none text-white shadow-sm"
          >
            {business}
          </p>
          <blockquote class="mt-3 text-sm leading-relaxed text-white drop-shadow-sm">
            &ldquo;{quote}&rdquo;
          </blockquote>
          {extra && (
            <p class="mt-2 text-xs leading-relaxed text-white/80">{extra}</p>
          )}
        </div>
      </div>
    )
  }
</article>
