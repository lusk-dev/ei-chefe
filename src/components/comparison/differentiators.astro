---
interface Props {
  className?: string;
}

import { cn } from '@/lib/utils';

const { className } = Astro.props;

const items = [
  {
    title: 'Estratégia antes da campanha',
    description:
      'Antes de anunciar, aprendemos sobre o negócio, o público, a oferta ativas dos concorrentes, histórico das campanhas, e o objetivo. Campanha sem direção vira desperdício.',
  },
  {
    title: 'Foco em dados que importam',
    description:
      'Alcance e muitos contatos podem ser úteis, mas o que realmente importa é contato QUALIFICADO, oportunidade, venda e ROI.',
  },
  {
    title: 'Olhar para conteúdo e posicionamento',
    description:
      'Além dos anúncios, você recebe recomendações de conteúdos, criativos e melhorias na comunicação para fortalecer a presença da marca.',
  },
  {
    title: 'Acompanhamento próximo',
    description:
      'O serviço é construído como parceria, com comunicação direta pelo whatsapp e decisões baseadas no momento real do negócio.',
  },
  {
    title: 'Visão da jornada completa',
    description:
      'Anúncio bom não salva atendimento ruim. Por isso, também olhamos para o caminho entre o clique, o WhatsApp, a reunião e a venda.',
  },
];
---

<section class={cn('px-4', className)}>
  <div class="max-w-[1620px] mx-auto w-full flex flex-col gap-10">
    <h2
      class="font-light italic text-[40px] md:text-[48px] leading-[120%] text-black max-w-[696px]"
    >
      Por que negócios e prestadores de serviço escolhem a Ei Chefe Ads
    </h2>

    <div class="flex flex-col gap-5 max-w-[844px] w-full ml-auto">
      {
        items.map((item, index) => (
          <div class="py-10 md:py-12 px-6 bg-black text-white flex flex-col gap-4 rounded-[40px]">
            <h3 class="text-[28px] md:text-[32px] leading-[116%] italic font-extrabold">
              {index + 1}. {item.title}
            </h3>
            <p class="text-base font-normal leading-[150%]">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
