---
interface Props {
  className?: string;
}

import { cn } from '@/lib/utils';

const { className } = Astro.props;

const consequences = [
  'menos pessoas descobrem seu negócio;',
  'concorrentes ocupam espaço na mente do cliente;',
  'sua agenda continua instável;',
  'você segue dependendo de indicação;',
  'oportunidades de venda deixam de chegar;',
  'seu crescimento fica preso ao acaso.',
];
---

<section class={cn('px-4', className)}>
  <div
    class="max-w-[1620px] mx-auto w-full py-12 px-6 md:px-10 bg-[#F3F3F3] rounded-[40px] flex flex-col gap-8"
  >
    <h2 class="font-light italic text-[40px] md:text-[48px] leading-[120%] text-black">
      O que acontece quando você adia a decisão?
    </h2>

    <p class="text-[#333] text-base leading-[150%]">
      Adiar o tráfego pago parece seguro porque você não aumenta o investimento
      hoje. Mas, enquanto isso:
    </p>

    <ul class="flex flex-col gap-2 text-[#333] text-base pl-4">
      {
        consequences.map(item => (
          <li class="list-disc">{item}</li>
        ))
      }
    </ul>

    <div class="flex flex-col gap-4 pt-4">
      <p class="text-[#333] text-base leading-[150%]">
        A pergunta não é apenas quanto custa contratar uma assessoria. A
        pergunta também é:
      </p>
      <p
        class="text-[#3219CA] text-2xl md:text-[32px] leading-[130%] font-medium italic"
      >
        Quanto custa continuar invisível para quem já está procurando pelo que
        você vende?
      </p>
    </div>
  </div>
</section>
