---
interface Props {
  className?: string;
}

import { cn } from '@/lib/utils';

import ChevronRightIcon from '@lucide/astro/icons/chevron-right';
import GemIcon from '@lucide/astro/icons/gem';
import RocketIcon from '@lucide/astro/icons/rocket';
import TrendingUpIcon from '@lucide/astro/icons/trending-up';

const { className } = Astro.props;
---

<div class={cn('bg-[#030406] py-20 md:py-24 px-6', className)}>
  <div class="mx-auto max-w-[1620px] w-full space-y-16 md:space-y-20">
    <div class="flex flex-col gap-6 md:flex-row">
      <div class="flex flex-col gap-10">
        <div class="space-y-6">
          <h2 class="text-white text-[48px] font-light italic leading-[60px]">
            Planos para escalar suas vendas → Aceleração de resultados
          </h2>

          <p class="text-white text-[24px] leading-[28.8px] font-normal">
            Assessoria de mídia paga
          </p>
        </div>
        <a
          href="/depoimentos"
          class="bg-[#1A1E38] cursor-pointer text-[#DDDDDD] rounded-[30px] font-semibold flex justify-center items-center gap-[10px] p-8 text-[26px] leading-[21px] max-w-[528px]"
        >
          VER DEPOIMENTOS
          <div
            class="size-[35px] text-white rounded-[17.5px] bg-[#2A51E6] flex justify-center items-center"
          >
            <ChevronRightIcon class="size-[14px]" />
          </div>
        </a>
      </div>

      <div class="p-6 flex flex-col gap-6 rounded-[40px] bg-[#1C1C1C] w-full">
        <span
          class="text-white/50 font-bold text-[32px] leading-[115.99999999999999%]"
          >Coloco sua empresa na frente de quem está pronto para comprar.
        </span>
        <p class="text-[24px] leading-[120%] font-normal text-white">
          Uso o poder dos anúncios online para atrair um fluxo constante de
          clientes, permitindo que você foque no que faz de melhor:
          <span class="italic font-medium text-[#604EE9]">
            gerenciar seu negócio.
          </span>
        </p>
      </div>
    </div>
    <div class="gap-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
      <article
        class="rounded-[28px] bg-[#F5F5F6] border border-[#D8D8DD] px-6 pt-6 pb-5 flex flex-col min-h-[720px]"
      >
        <div class="flex-1 space-y-5 text-[#1B1D22]">
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div
                class="size-10 rounded-xl bg-[#ECEAFB] text-[#4C37DA] flex items-center justify-center text-lg"
              >
                <RocketIcon class="size-5" />
              </div>
              <h3 class="leading-tight">
                <span class="block italic font-light text-[38px]">Quero começar,</span>
                <span class="block text-[43px] font-bold">Chefe</span>
              </h3>
            </div>
            <div class="border-y border-[#D9D9DE] py-2.5">
              <p class="text-[#6A6D75] text-[18px]">Ideal até R$ 2.000/mês em anúncios</p>
            </div>
          </div>

          <div class="space-y-1">
            <p class="text-[#8D9098] text-[35px] leading-none line-through">
              R$ 1.997/mês
            </p>
            <p class="text-[69px] font-bold leading-[0.95] tracking-tight">
              R$ 997<span class="text-[47px] font-semibold">/mês</span>
            </p>
            <p class="text-[#4331D7] text-[34px] font-bold leading-tight">
              ou 6x de R$ 166 no cartão
            </p>
            <p class="pt-1 text-[#666A73] text-[17px]">Contrato mínimo de 6 meses</p>
          </div>

          <div class="border-t border-[#D9D9DE] pt-5 space-y-5">
            <div class="space-y-2">
              <p class="font-bold text-[30px]">O que está incluso</p>
              <ul class="space-y-1.5 text-[26px] text-[#30343D]">
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Planejamento</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Análise de Dados</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Planejamento de Crescimento</span>
                </li>
              </ul>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-[30px]">Análise de posicionamento de marca</p>
              <ul class="space-y-1.5 text-[26px] text-[#30343D]">
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Sugestões de conteúdos</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Sugestões de edições de vídeos</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span
                  ><span>Sugestão para landing pages (páginas de alta conversão)</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <a
          href="/depoimentos"
          class="mt-6 rounded-full bg-[#0F1115] hover:bg-[#1B1D22] text-white text-[39px] font-semibold px-8 py-5 flex items-center justify-center gap-5 transition-colors"
        >
          Ver depoimentos
          <ChevronRightIcon class="size-8" />
        </a>
        <p class="mt-4 text-[#6D717A] text-[17px] text-center">
          🔒 Acesso seguro e suporte especializado
        </p>
      </article>

      <article
        class="rounded-[28px] bg-[#F5F5F6] border-2 border-[#6959E8] px-6 pt-6 pb-5 flex flex-col min-h-[720px] relative shadow-[0_0_25px_rgba(90,70,238,0.28)]"
      >
        <span
          class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-[#4A39D9] text-white text-[16px] font-semibold px-5 py-1.5"
        >
          ✦ Mais escolhido
        </span>

        <div class="flex-1 space-y-5 text-[#1B1D22]">
          <div class="space-y-3 pt-2">
            <div class="flex items-center gap-3">
              <div
                class="size-10 rounded-xl bg-[#ECEAFB] text-[#4C37DA] flex items-center justify-center text-lg"
              >
                <TrendingUpIcon class="size-5" />
              </div>
              <h3 class="leading-tight">
                <span class="block italic font-light text-[38px]">Bora aumentar,</span>
                <span class="block text-[43px] font-bold">Chefe</span>
              </h3>
            </div>
            <div class="border-y border-[#D9D9DE] py-2.5">
              <p class="text-[#5E49E6] text-[18px] font-semibold">
                De R$ 2.000 a R$ 5.000/mês em anúncios
              </p>
            </div>
          </div>

          <div class="space-y-1">
            <p class="text-[#8D9098] text-[35px] leading-none line-through">
              R$ 2.997/mês
            </p>
            <p class="text-[69px] font-bold leading-[0.95] tracking-tight">
              R$ 1.997<span class="text-[47px] font-semibold">/mês</span>
            </p>
            <p class="text-[#4331D7] text-[34px] font-bold leading-tight">
              ou 6x de R$ 332 no cartão
            </p>
            <p class="pt-1 text-[#666A73] text-[17px]">Contrato mínimo de 6 meses</p>
          </div>

          <div class="border-t border-[#D9D9DE] pt-5 space-y-5">
            <div class="space-y-2">
              <p class="font-bold text-[30px]">Tudo do plano Começar, mais:</p>
              <ul class="space-y-1.5 text-[26px] text-[#30343D]">
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Assessoria de mídia paga</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Tudo do outro modelo +</span>
                </li>
              </ul>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-[30px]">Assessoria de análise de dados 🔎</p>
              <ul class="space-y-1.5 text-[26px] text-[#30343D]">
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Gestão em multiplataforma de anúncio</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Configuração de Tags e Pixels</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span
                  ><span>Análise da velocidade do site (trimestral)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4E3BDD]">●</span><span>Benchmarking de concorrentes e anúncios</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <a
          href="/depoimentos"
          class="mt-6 rounded-full bg-[#4E3BDD] hover:bg-[#5C49E9] text-white text-[39px] font-semibold px-8 py-5 flex items-center justify-center gap-5 transition-colors"
        >
          Ver depoimentos
          <ChevronRightIcon class="size-8" />
        </a>
        <p class="mt-4 text-[#6D717A] text-[17px] text-center">
          🔒 Acesso seguro e suporte prioritário
        </p>
      </article>

      <article
        class="rounded-[28px] border border-[#6354E6] px-6 pt-6 pb-5 flex flex-col min-h-[720px] relative overflow-hidden text-white"
        style="background: radial-gradient(120% 85% at 50% 100%, rgba(102, 82, 255, 0.4) 0%, rgba(9, 11, 28, 0.96) 42%, #05060F 100%);"
      >
        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-[45%] bg-gradient-to-t from-[#6B58F0]/40 to-transparent"
        >
        </div>

        <div class="relative z-10 flex-1 space-y-5">
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div
                class="size-10 rounded-xl border border-[#5D4BE0] bg-[#1A1640] text-[#9E90FF] flex items-center justify-center text-lg"
              >
                <GemIcon class="size-5" />
              </div>
              <h3 class="leading-tight">
                <span class="block italic font-light text-[38px]">Quero evoluir,</span>
                <span class="block text-[43px] font-bold">Modo Especialista</span>
              </h3>
            </div>
            <div class="border-y border-white/15 py-2.5">
              <p class="text-[#9A8CFF] text-[18px] font-semibold">
                Acima de R$ 5.000/mês em anúncios
              </p>
            </div>
          </div>

          <div class="space-y-1">
            <p class="text-white/45 text-[35px] leading-none line-through">
              R$ 5.997/mês
            </p>
            <p class="text-[69px] font-bold leading-[0.95] tracking-tight">
              R$ 3.997<span class="text-[47px] font-semibold">/mês</span>
            </p>
            <p class="text-[#9A8CFF] text-[34px] font-bold leading-tight">
              ou 6x de R$ 666 no cartão
            </p>
            <p class="pt-1 text-white/80 text-[17px]">Contrato mínimo de 6 meses</p>
          </div>

          <div class="border-t border-white/15 pt-5 space-y-5">
            <div class="space-y-2">
              <p class="font-bold text-[30px]">Tudo do plano Aumentar, mais:</p>
              <ul class="space-y-1.5 text-[26px] text-white/90">
                <li class="flex items-start gap-2">
                  <span class="text-[#8E7EFF]">●</span><span>Assessoria de mídia paga</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#8E7EFF]">●</span><span>Assessoria de análise de dados</span>
                </li>
              </ul>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-[30px]">Tudo do outro modelo +</p>
              <ul class="space-y-1.5 text-[26px] text-white/90">
                <li class="flex items-start gap-2">
                  <span class="text-[#8E7EFF]">●</span><span>Criação de criativos com IA (new)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#8E7EFF]">●</span
                  ><span>Assessoria de vendas e resultados no processo comercial</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#8E7EFF]">●</span><span>Análise da jornada para identificação do ICP</span>
                </li>
              </ul>
            </div>
            <div class="flex items-start gap-3 text-[16px]">
              <span
                class="shrink-0 rounded-full border border-[#6C5EF0] bg-[#342A7E] px-3 py-1 font-semibold text-[#C8C0FF]"
              >
                ✦ Exclusivo
              </span>
              <p class="text-white/90">
                1 treinamento de atendimento/vendas com parceiros estratégicos
                com foco em melhorar a conversão de vendas | ANUAL
              </p>
            </div>
          </div>
        </div>

        <a
          href="/depoimentos"
          class="relative z-10 mt-6 rounded-full bg-[#4E3BDD] hover:bg-[#5C49E9] text-white text-[39px] font-semibold px-8 py-5 flex items-center justify-center gap-5 transition-colors"
        >
          Ver depoimentos
          <ChevronRightIcon class="size-8" />
        </a>
        <p class="relative z-10 mt-4 text-white/65 text-[17px] text-center">
          🔒 Acesso seguro e suporte VIP
        </p>
      </article>
    </div>
  </div>
</div>
